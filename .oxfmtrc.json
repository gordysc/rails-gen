{
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "printWidth": 80,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false,
  "svelte": true,
  "sortTailwindcss": {
    "stylesheet": "./src/routes/layout.css",
    "functions": ["cn", "tv", "cva", "buttonVariants"]
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "bun.lock",
    "bun.lockb",
    "/static/"
  ]
}
